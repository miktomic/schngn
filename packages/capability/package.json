{
  "name": "@schngn/capability",
  "version": "0.1.1",
  "description": "Strict local TypeScript contract for ordinary Schengen 90/180-day planning.",
  "keywords": [
    "schengen",
    "90-180",
    "agent",
    "typescript",
    "zod"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./dist/index.js",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miktomic/schngn.git",
    "directory": "packages/capability"
  },
  "homepage": "https://schngn.com/agents",
  "bugs": {
    "url": "https://github.com/miktomic/schngn/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@schngn/engine": "0.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
