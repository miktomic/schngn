{
  "name": "@schngn/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --assets .svelte-kit/cloudflare",
    "deploy": "vite build && wrangler deploy",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@schngn/engine": "workspace:*",
    "@sveltejs/adapter-cloudflare": "^7.2.2",
    "@sveltejs/kit": "^2.48.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "svelte": "^5.45.1",
    "vite": "^7.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "svelte-check": "^4.3.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.45.0"
  }
}
