# Infisical `dev` at /apps/web is the authoritative local source.
# This value-free file is an offline fallback only: copy it to .env.local and
# add matching keys from the Clerk Development instance. Never use live keys.
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: only needed when testing Clerk account-deletion webhooks locally.
CLERK_WEBHOOK_SIGNING_SECRET=

# Optional: only needed when testing the contact form locally.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
